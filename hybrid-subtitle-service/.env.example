# Provider credentials. Never commit real keys.
MIMO_API_KEY=
DEEPGRAM_API_KEY=

# Protect the public service. Clients may send X-API-Key or Bearer auth.
SERVICE_API_KEY=replace-with-a-long-random-value

DATA_DIR=./data
MAX_UPLOAD_MB=1024
CHUNK_SECONDS=45
CHUNK_OVERLAP_SECONDS=0.8
PROVIDER_TIMEOUT_SECONDS=120
PROVIDER_MAX_RETRIES=3
CHUNK_CONCURRENCY=2
JOB_CONCURRENCY=2

MIMO_BASE_URL=https://api.xiaomimimo.com/v1/chat/completions
MIMO_MODEL=mimo-v2.5-asr
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3
DEEPGRAM_MIP_OPT_OUT=false

# `auto` prefers Deepgram when its key is present. Set `faster-whisper` for a
# self-hosted timestamp fallback; MiMo remains the text source in both modes.
TIMESTAMP_PROVIDER=auto
FASTER_WHISPER_MODEL=
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# Comma-separated browser origins. Leave empty for server-to-server use.
CORS_ORIGINS=
