// Debug follows the same Pages API contract as Web. Unit tests inject their
// own URLSession/base URL; a local agent override stays untracked.
MOONCUT_API_BASE_URL = https:/$()/mooncut.me/api
MOONCUT_TRUSTED_HOST = mooncut.me
MOONCUT_TLS_MODE = system
MOONCUT_DISTRIBUTION_MODE = debug
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) DEBUG
