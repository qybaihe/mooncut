{
  "name": "remocn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "registry:build": "shadcn build && biome format --write public/r",
    "registry:check": "shadcn build && biome format --write public/r && git diff --quiet -- public/r || (echo 'public/r is out of sync with registry/ sources. Run: bun run registry:build and commit the result.' && exit 1)",
    "remotion:browser": "bun scripts/ensure-browser.mts",
    "bundle:remotion": "bun scripts/bundle-remotion.mts",
    "render:demos": "bun scripts/render-demos.mts",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@openpanel/nextjs": "^1.0.13",
    "@paper-design/shaders-react": "0.0.76",
    "@remotion/bundler": "4.0.473",
    "@remotion/google-fonts": "4.0.473",
    "@remotion/player": "4.0.473",
    "@remotion/renderer": "4.0.473",
    "@remotion/transitions": "4.0.473",
    "@shadcn/react": "^0.1.0",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.1",
    "date-fns": "^4.1.0",
    "fumadocs-core": "^16.7.10",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.10",
    "jotai": "^2.19.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.40.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "p-limit": "^6.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.9.0",
    "remotion": "4.0.473",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "latest",
    "@types/culori": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
