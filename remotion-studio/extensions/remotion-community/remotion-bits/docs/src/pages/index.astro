---
import "../styles/custom.css";
import { HeroShowcase } from "@/components/showcases/HeroShowcase";
import { ParticlesCardShowcase } from "@/components/showcases/ParticlesCardShowcase";
import { MotionPrimitivesCardIcon } from "@/components/showcases/MotionPrimitivesCardIcon";
import { Code } from "@astrojs/starlight/components";
import BentoCard from "@/components/BentoCard.astro";
import Logo from "@/components/Logo.astro";
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Remotion Bits - Building Blocks for Video</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <meta
      name="description"
      content="Open Source component kit for Remotion. Save time building programmatic videos."
    />
  </head>
  <body
    class="bg-background-dark text-slate-200 font-sans antialiased selection:bg-primary selection:text-white overflow-x-hidden"
  >
    <div class="relative w-full min-h-screen">
      <div
        class="fixed top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-primary/10 blur-[120px] rounded-full pointer-events-none z-0"
      >
      </div>
      <div
        class="fixed bottom-0 right-0 w-[600px] h-[600px] bg-white/5 blur-[120px] rounded-full pointer-events-none z-0"
      >
      </div>
      <div
        class="fixed inset-0 bg-[size:40px_40px] opacity-[0.15] pointer-events-none z-0"
      >
      </div>
      <nav
        class="fixed top-0 w-full z-50 border-b border-white/5 bg-background-dark/80 backdrop-blur-md"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <div class="flex items-center gap-2">
              <Logo size="md" class="text-primary" />
              <span class="font-bold text-xl tracking-tight text-white"
                >Remotion Bits</span
              >
            </div>
            <div
              class="hidden md:flex space-x-8 text-sm font-medium text-gray-400"
            >
              <a
                class="hover:text-primary transition-colors"
                href="/docs/getting-started">Documentation</a
              >
            </div>
            <div class="flex items-center gap-4">
              <a
                class="group flex items-center gap-2 bg-white/5 hover:bg-white/10 text-white px-3 py-1.5 rounded-md squircle text-xs font-medium border border-white/10 transition-all"
                href="https://github.com/av/remotion-bits"
                target="_blank"
              >
                <svg
                  class="w-4 h-4 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"
                  ></path></svg
                >
                <span>Star on GitHub</span>
              </a>
            </div>
          </div>
        </div>
      </nav>
      <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-24 z-10">
        <div
          class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center"
        >
          <button
            id="hero-npm-install"
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-xs font-mono text-primary mb-8 animate-fade-in-up cursor-pointer hover:bg-primary/20 transition-colors"
          >
            <span class="material-symbols-outlined text-sm">terminal</span>
            npm install remotion-bits
          </button>
          <h1
            class="text-6xl md:text-8xl lg:text-9xl font-bold tracking-tight text-white mb-8 leading-[1.1] md:leading-[1.1]"
          >
            Building blocks <br />
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-400 to-gray-600"
              >for your videos</span
            >
          </h1>
          <p
            class="mt-2 max-w-2xl mx-auto text-lg md:text-xl text-gray-400 mb-10 leading-relaxed"
          >
            Open Source component kit for Remotion. <br
              class="hidden md:block"
            />Save time building programmatic videos.
          </p>
          <div
            class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-20 w-full sm:w-auto"
          >
            <a
              class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-lg squircle bg-white px-8 font-medium text-black transition-all duration-300 hover:bg-gray-200 hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-black w-full sm:w-auto"
              href="https://github.com/av/remotion-bits"
              target="_blank"
            >
              <span class="material-symbols-outlined mr-2 text-xl">star</span>
              <span class="mr-1">Star on GitHub</span>
            </a>
            <a
              class="group inline-flex h-12 items-center justify-center rounded-lg squircle border border-white/20 bg-white/5 px-8 font-medium text-white transition-all duration-300 hover:bg-white/10 hover:border-white/30 w-full sm:w-auto"
              href="/docs/getting-started"
            >
              <span class="mr-2">Get Started</span>
              <span
                class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform"
                >arrow_forward</span
              >
            </a>
          </div>
          <HeroShowcase
            client:only="react"
            bitNames={[
              "ParticlesFountain",
              "BlurSlideWord",
              "LinearGradient",
              "FlyingThroughWords",
              "ParticlesGrid",
              "3DElements",
            ]}
          />
        </div>
      </section>
      <section class="py-24 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-16">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
              Designed for engineers.
            </h2>
            <p class="text-gray-400 text-lg max-w-2xl">
              Skip the After Effects license. Build complex motion graphics with
              the tools you already know and love.
            </p>
          </div>
          <div
            class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-6 gap-4 md:gap-6 auto-rows-[250px] md:auto-rows-[280px]"
          >
            <BentoCard class="md:col-span-6 lg:col-span-4">
              <div
                class="relative z-10 h-full flex flex-col md:flex-row gap-8 items-center"
              >
                <div class="flex-1 min-w-0">
                  <div
                    class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-4 border border-primary/20"
                  >
                    <span class="material-symbols-outlined text-2xl"
                      >text_fields</span
                    >
                  </div>
                  <h3 class="text-2xl font-semibold text-white mb-2">
                    Text Effects
                  </h3>
                  <p class="text-gray-400 text-sm max-w-md">
                    Create complex typography animations with ease. Stagger
                    characters, words, or lines. Combine blur, scale, and
                    position offsets for professional reveals.
                  </p>
                </div>
                <div class="flex-1 w-full hidden md:block">
                  <div
                    class="rounded-lg overflow-hidden border border-white/10 shadow-xl bg-[#0d1117] text-xs"
                  >
                    <Code
                      code={`<AnimatedText
  transition={{
    y: [40, 0],
    blur: [10, 0], // Word-by-word blur
    opacity: [0, 1],
    split: "word",
    splitStagger: 1,
  }}
>
  Text Transition
</AnimatedText>`}
                      lang="tsx"
                    />
                  </div>
                </div>
              </div>
            </BentoCard>
            <BentoCard class="md:col-span-3 lg:col-span-2">
              <div class="absolute inset-0 z-0">
                <ParticlesCardShowcase client:only="react" />
              </div>
              <div class="relative z-10 h-full flex flex-col">
                <div
                  class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-4 border border-primary/20 bg-surface-light/80 backdrop-blur-sm"
                >
                  <span class="material-symbols-outlined text-2xl">grain</span>
                </div>
                <h3 class="text-xl font-semibold text-white mb-2">
                  Particle System
                </h3>
                <p class="text-gray-400 text-sm mb-4">
                  A complete physics-based particle engine. Simulate rain,
                  confetti, or starfields with customizable behaviors.
                </p>
              </div>
            </BentoCard>
            <BentoCard class="md:col-span-3 lg:col-span-2">
              <div class="relative z-10">
                <MotionPrimitivesCardIcon client:visible />
                <h3 class="text-xl font-semibold text-white mb-2">
                  Motion Primitives
                </h3>
                <p class="text-gray-400 text-sm">
                  Declarative entry and exit animations. Chain fades, slides,
                  and scaling without managing complex interpolations manually.
                </p>
              </div>
            </BentoCard>
            <BentoCard class="md:col-span-3 lg:col-span-2">
              <div
                class="absolute inset-0 z-0 bg-cover bg-top"
                style="background-image: url('/suggestion.png'); mask-image: linear-gradient(to top, black, transparent 40%);"
              >
              </div>
              <div class="relative z-10 h-full">
                <div
                  class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-4 border border-primary/20"
                >
                  <span class="material-symbols-outlined text-2xl"
                    >integration_instructions</span
                  >
                </div>
                <h3 class="text-xl font-semibold text-white mb-2">Type Safe</h3>
                <p class="text-gray-400 text-sm mb-4">
                  First-class TypeScript support. Autocomplete for every prop
                  and component.
                </p>
              </div>
            </BentoCard>
            <BentoCard class="md:col-span-3 lg:col-span-2 flex flex-col">
              <div class="relative z-10 flex-1">
                <div
                  class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-4 border border-primary/20"
                >
                  <span class="material-symbols-outlined text-2xl"
                    >content_copy</span
                  >
                </div>
                <h3 class="text-xl font-semibold text-white mb-2">
                  Copy-Paste Ready
                </h3>
                <p class="text-gray-400 text-sm">
                  Install components directly into your codebase. Own the
                  source, customize endlessly, and suffer zero bloat.
                </p>
              </div>
            </BentoCard>
          </div>
        </div>
      </section>
      <section
        class="py-24 bg-gradient-to-b from-background-dark to-black border-t border-white/5"
      >
        <div class="max-w-4xl mx-auto px-4 text-center">
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-8">
            Start creating in seconds.
          </h2>
          <div
            class="bg-surface-dark border border-white/10 rounded-xl squircle p-4 md:p-8 max-w-2xl mx-auto shadow-2xl relative overflow-hidden group"
          >
            <div
              class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"
            >
            </div>
            <div
              class="flex items-center justify-between gap-4 font-mono text-sm md:text-lg"
            >
              <div class="flex items-center gap-3">
                <span class="text-primary font-bold">➜</span>
                <span class="text-gray-300">npm install</span>
                <span class="text-white font-bold">remotion-bits</span>
              </div>
              <button
                id="copy-npm-install"
                aria-label="Copy"
                class="text-gray-500 hover:text-white transition-colors"
              >
                <span class="material-symbols-outlined">content_copy</span>
              </button>
            </div>
          </div>
          <p class="text-gray-500 mt-8 text-sm">
            Requires React 18+ and Remotion 4.0+. <br />
            <a class="text-primary hover:underline" href="/docs/getting-started"
              >Read the setup guide</a
            >
          </p>
        </div>
      </section>
      <footer class="bg-black border-t border-white/5 pt-16 pb-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div
            class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 mb-12"
          >
            <div class="col-span-2 lg:col-span-2">
              <div class="flex items-center gap-2 mb-4">
                <Logo size="md" class="text-primary" />
                <span class="font-semibold text-white">Remotion Bits</span>
              </div>
              <p class="text-gray-500 text-sm mb-6 max-w-xs">
                Composable animation components for Remotion.
              </p>
              <div class="flex gap-4">
                <a
                  class="text-gray-500 hover:text-white transition-colors"
                  href="https://x.com/Everlier"
                  ><span class="sr-only">X</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                    ><path
                      d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.694l-5.195-6.791-5.963 6.791H2.882l7.605-8.696-8.212-10.804h6.888l4.784 6.335 5.592-6.335zM16.369 20.033h1.83L7.923 4.14h-1.95l9.396 15.893z"
                    ></path></svg
                  >
                </a>
                <a
                  class="text-gray-500 hover:text-white transition-colors"
                  href="https://github.com/av/remotion-bits"
                  target="_blank"
                  ><span class="sr-only">GitHub</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                    ><path
                      clip-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                      fill-rule="evenodd"></path></svg
                  >
                </a>
              </div>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-4 text-sm">Library</h3>
              <ul class="space-y-2 text-sm text-gray-500">
                <li>
                  <a class="hover:text-primary transition-colors" href="/docs/reference/staggered-motion"
                    >Components</a
                  >
                </li>
                <li>
                  <a class="hover:text-primary transition-colors" href="/docs/reference/use-viewport-rect"
                    >Hooks</a
                  >
                </li>
                <li>
                  <a class="hover:text-primary transition-colors" href="/docs/reference/utils-interpolation"
                    >Utils</a
                  >
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-4 text-sm">Community</h3>
              <ul class="space-y-2 text-sm text-gray-500">
                <li>
                  <a class="hover:text-primary transition-colors" href="#"
                    >GitHub</a
                  >
                </li>
              </ul>
            </div>
          </div>
          <div
            class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4"
          >
            <p class="text-gray-600 text-xs">
              © <span id="year"></span> Remotion Bits. Open source software.
            </p>
          </div>
        </div>
      </footer>
    </div>
    <script>
      // Set current year dynamically
      const yearElement = document.getElementById("year");
      if (yearElement) {
        yearElement.textContent = new Date().getFullYear().toString();
      }

      const copyButton = document.getElementById("copy-npm-install");
      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText("npm install remotion-bits");

            const icon = copyButton.querySelector(".material-symbols-outlined");
            if (icon) {
              const originalText = icon.textContent ?? "";
              icon.textContent = "check";
              icon.classList.add("text-primary"); // Add green color for feedback

              setTimeout(() => {
                icon.textContent = originalText;
                icon.classList.remove("text-primary");
              }, 2000);
            }
          } catch (err) {
            console.error("Failed to copy:", err);
          }
        });
      }

      const heroCopyButton = document.getElementById("hero-npm-install");
      if (heroCopyButton) {
        heroCopyButton.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText("npm install remotion-bits");

            const icon = heroCopyButton.querySelector(
              ".material-symbols-outlined",
            );
            if (icon) {
              const originalText = icon.textContent ?? "";
              icon.textContent = "check";
              icon.classList.add("text-primary");

              setTimeout(() => {
                icon.textContent = originalText;
                icon.classList.remove("text-primary");
              }, 2000);
            }
          } catch (err) {
            console.error("Failed to copy:", err);
          }
        });
      }
    </script>
  </body>
</html>
