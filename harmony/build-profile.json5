      }
    ],
    "buildModeSet": [
      { "name": "debug" },
      { "name": "release" },
      { "name": "test" }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": ["default", "emulator"]
        }
      ]
    }
  ]
