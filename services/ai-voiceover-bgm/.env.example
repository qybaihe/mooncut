# 云雾 API 密钥只能放在服务端环境变量或本目录未跟踪的 .env 中，不能写进前端代码。
# 复制本文件为 .env 后再填写真实值；不要提交 .env。
YUNWU_API_KEY=
YUNWU_BASE_URL=https://api.yunwu.ai

# Suno 任务接口。若云雾控制台文档中的路径不同，只改这里即可。
YUNWU_SUNO_SUBMIT_PATH=/suno/submit/music
YUNWU_SUNO_FETCH_PATH=/suno/fetch/{task_id}
YUNWU_SUNO_MODEL=chirp-v5

# 用同一云雾 Key 调用 OpenAI 兼容模型分析口播文案；失败时自动降级到本地规则。
YUNWU_ANALYSIS_ENABLED=true
YUNWU_ANALYSIS_PATH=/v1/chat/completions
YUNWU_ANALYSIS_MODEL=gpt-4o-mini

# 对外服务设置。SERVICE_API_KEY 为必填项；使用至少 32 位随机值。
HOST=0.0.0.0
PORT=8787
SERVICE_API_KEY=
PUBLIC_BASE_URL=http://localhost:8787

# 轮询与任务设置。
POLL_INTERVAL_MS=5000
GENERATION_TIMEOUT_MS=600000
MAX_CONCURRENT_JOBS=2
DATA_DIR=./data

# 配乐后处理。Docker 镜像已内置 ffmpeg。
FFMPEG_PATH=ffmpeg
BGM_VOLUME_DB=-18
FADE_SECONDS=1.5
AUDIO_PROCESSING_REQUIRED=false
DOWNLOAD_TIMEOUT_MS=60000
MAX_AUDIO_BYTES=52428800
