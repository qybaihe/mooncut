# 本地开发：直连本地 Agent
VITE_MOONCUT_API_BASE_URL=http://127.0.0.1:4317

# 生产（Cloudflare Pages）：留空或设为 /api，走同域反代。
# 不设此变量时默认 /api，由 functions/api/[[path]].ts 转发到 Agent。
# VITE_MOONCUT_API_BASE_URL=/api

# Community packages live in this Pages project's D1 database. No external
# registry origin is needed; AGENT_ORIGIN is required only for “连接到 Agent”.

# Billing is configured in Cloudflare Pages, not exposed to the browser:
# BILLING_CHECKOUT_URL=https://checkout.example.com/mooncut
# BILLING_CHECKOUT_SIGNING_SECRET=<long-random-HMAC-secret-shared-with-checkout-backend>
# BILLING_WEBHOOK_SECRET=<long-random-server-to-server-secret>
