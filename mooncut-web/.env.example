# 本地开发：直连本地 Agent
VITE_MOONCUT_API_BASE_URL=http://127.0.0.1:4317

# 生产（Cloudflare Pages）：留空或设为 /api，走同域反代。
# 不设此变量时默认 /api，由 functions/api/[[path]].ts 转发到 Agent。
# VITE_MOONCUT_API_BASE_URL=/api

# EdgeOne community registry. Update only when you intentionally release a new registry origin.
VITE_MOONCUT_COMMUNITY_REGISTRY_URL=https://mc.classby.cn
