{
  "name": "@mooncut/pi-video-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi-powered talking-head video editing agent for MoonCut",
  "keywords": [
    "pi-package",
    "remotion",
    "video-editing-agent"
  ],
  "pi": {
    "skills": [
      "./.pi/skills"
    ]
  },
  "scripts": {
    "serve": "node --experimental-strip-types src/cli.ts serve",
    "edit": "node --experimental-strip-types src/cli.ts edit",
    "edit:grok": "MOONCUT_AGENT_EXECUTION_MODE=grok node --experimental-strip-types src/cli.ts edit",
    "edit:codex": "MOONCUT_AGENT_EXECUTION_MODE=codex node --experimental-strip-types src/cli.ts edit",
    "models": "node --experimental-strip-types src/cli.ts models",
    "tool": "node --experimental-strip-types src/cli.ts tool",
    "build:studio": "node scripts/build-studio-entry.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:studio && node --experimental-strip-types --test test/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
