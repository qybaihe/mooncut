MOONCUT_GATEWAY_BASE_URL=http://localhost:8080/v1
MOONCUT_GATEWAY_API_KEY=
MOONCUT_PLANNER_MODEL=glm-5.2
MOONCUT_SCRIPT_MODEL=glm-5.2
MOONCUT_COACH_MODEL=deepseek-v4-flash
MOONCUT_IMAGE_BASE_URL=
MOONCUT_IMAGE_API_KEY=
MOONCUT_IMAGE_MODEL=
MOONCUT_IMAGE_MAX_IMAGES=2
MOONCUT_IMAGE_SIZE=1536x1024
MOONCUT_IMAGE_TIMEOUT_MS=180000
MOONCUT_VISION_MODELS=minimax-m3,mimo-v2.5
MOONCUT_AGENT_HOST=127.0.0.1
MOONCUT_AGENT_PORT=4317
# Leave false for desktop-only localhost. A Tunnel/network deployment must set
# this true; Agent startup then requires all security settings below.
MOONCUT_PUBLIC_DEPLOYMENT=false
MOONCUT_PUBLIC_BASE_URL=http://127.0.0.1:4317
MOONCUT_API_KEY=replace-with-a-random-client-api-key
MOONCUT_ALLOW_INPUT_PATH=false
MOONCUT_MAX_QUEUED_JOBS=8
MOONCUT_RENDER_CONCURRENCY=1
MOONCUT_BROWSER_EXECUTABLE=
MOONCUT_DATABASE_PATH=./data/mooncut.sqlite
# Immutable Capability release integrity. Replace in production before accepting admin releases.
MOONCUT_CAPABILITY_SIGNING_KEY=replace-with-a-long-random-capability-signing-key
MOONCUT_CAPABILITY_ARTIFACTS_ROOT=./data/capability-artifacts
# The bundled official FIFA adapter runs this built Node CLI with allowlisted argv only.
MOONCUT_FIFA_CLI_PATH=../fifa-highlights-cli/dist/index.js
MOONCUT_FIFA_CLI_CWD=../fifa-highlights-cli
MOONCUT_SESSION_DAYS=30
# Required when MOONCUT_PUBLIC_DEPLOYMENT=true.
MOONCUT_COOKIE_SECURE=false
# Required when MOONCUT_PUBLIC_DEPLOYMENT=true. Browser auth stays on Pages;
# direct Agent registration/login is disabled.
MOONCUT_EDGE_AUTH_ONLY=false
MOONCUT_MAX_UPLOAD_MB=1024
MOONCUT_MAIL_CLI=/opt/homebrew/bin/agently-cli
MOONCUT_MAIL_SENDER_NAME=MoonCut 小月
# agently-cli | webhook | resend
MOONCUT_MAIL_TRANSPORT=resend
MOONCUT_MAIL_AUTO_SEND=true
# Attach the ~20MB preview (final-mail.mp4). Full-quality master stays local as final.mp4.
MOONCUT_MAIL_ATTACH_VIDEO=true
MOONCUT_MAIL_PREVIEW_TARGET_MB=20
# Post-render mail re-encode only — does not change Remotion export resolution
MOONCUT_MAIL_PREVIEW_MAX_HEIGHT=720
# Hard cap for attachment raw size (Resend total message ≤40MB incl. Base64)
MOONCUT_MAIL_ATTACH_MAX_MB=22
MOONCUT_MAIL_MEMBERSHIP_URL=https://mooncut.me
MOONCUT_MAIL_WEBHOOK_URL=
MOONCUT_MAIL_WEBHOOK_TOKEN=
# Resend: verified domain sender, or onboarding@resend.dev for sandbox tests
MOONCUT_MAIL_FROM_ADDRESS=MoonCut 小月 <onboarding@resend.dev>
MOONCUT_RESEND_API_KEY=
# Required separately in public deployments; never reuse the API key for links.
MOONCUT_MAIL_DOWNLOAD_SECRET=
MOONCUT_MAIL_DOWNLOAD_TTL_HOURS=168
# Must be a public Tunnel URL so recipients can open download links
# MOONCUT_PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com
MOONCUT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MOONCUT_SUBTITLE_API_URL=http://127.0.0.1:8765
MOONCUT_SUBTITLE_API_KEY=integration-test
# Production: keep false, so every upload uses the service rather than a checked-in fixture.
MOONCUT_ALLOW_KNOWN_SUBTITLE_FIXTURES=false
# Production: fail visibly if MiMo-backed subtitles are unavailable; never silently downgrade.
MOONCUT_REQUIRE_SUBTITLE_SERVICE=true
MOONCUT_SUBTITLE_JOB_TIMEOUT_MS=2700000
MOONCUT_SUBTITLE_POLL_INTERVAL_MS=2000
# 1080p desktop composition on CPU-only infrastructure needs a long allowance.
MOONCUT_RENDER_TIMEOUT_MS=7200000
# Default server delivery profile: 16:9, review-ready and viable on a small CPU worker.
MOONCUT_RENDER_WIDTH=1280
MOONCUT_RENDER_HEIGHT=720
MOONCUT_RENDER_FPS=24
# `reliable` = deterministic pipeline (production default)
# `pi`       = experimental Pi coding-agent planner
# `grok`     = Grok Build headless agent over the same tools (Pi replacement path)
MOONCUT_AGENT_EXECUTION_MODE=reliable
# Grok mode (only used when MOONCUT_AGENT_EXECUTION_MODE=grok)
# MOONCUT_GROK_BINARY=grok
# MOONCUT_GROK_MODEL=grok-4.5
# MOONCUT_GROK_REASONING_EFFORT=max
# MOONCUT_GROK_MAX_TURNS=120
# MOONCUT_GROK_TIMEOUT_MS=2700000
MOONCUT_TRANSCRIBE_PYTHON=./.venv-transcribe/bin/python
MOONCUT_WHISPER_MODEL=small
MOONCUT_WHISPER_LANGUAGE=auto
MOONCUT_WHISPER_THREADS=4
MOONCUT_X_POST_CAPTURE_SCRIPT=~/.codex/skills/x-post-screenshot/scripts/x_post_capture.py
MOONCUT_PLAYWRIGHT_CLI=~/.codex/skills/playwright/scripts/playwright_cli.sh
